# ============================================
# Umgebungsvariablen für chuchipirat
# Kopiere diese Datei als .env.development, .env.test oder .env.production
# und fülle die Werte aus.
# ============================================

# ── Umgebung ──
# Mögliche Werte: DEV, TST, PRD
VITE_ENVIRONMENT=DEV

# ── Firebase (Authentifizierung) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_CONFIRMATION_EMAIL_REDIRECT=

# ── Supabase (Datenbank) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# NUR für lokale Entwicklung (Docker). NIEMALS in TST/PRD setzen!
# VITE_SUPABASE_SERVICE_ROLE_KEY=

# ── Sentry (Fehler-Tracking) ──
VITE_SENTRY_DSN=

# ── Umami (Analytics) ──
VITE_UMAMI_HOST=
VITE_UMAMI_WEBSITE_ID=

# ── Sonstiges ──
VITE_SUPPORT_USER_ID=
