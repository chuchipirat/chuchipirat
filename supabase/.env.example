# ============================================
# Supabase Backend — Umgebungsvariablen (Coolify)
#
# Diese Datei dokumentiert alle Umgebungsvariablen, die Coolify für
# den Supabase-Service benötigt. Coolify entfernt Kommentare beim
# Einfügen — diese Datei dient daher als strukturierte Referenz.
#
# Variablen mit ${SERVICE_...} werden von Coolify automatisch aufgelöst.
# ============================================


############
# Coolify Service-Passwörter & Keys
# Werden von Coolify generiert und intern referenziert.
############

SERVICE_PASSWORD_POSTGRES=
SERVICE_PASSWORD_JWT=
SERVICE_PASSWORD_MINIO=
SERVICE_PASSWORD_SUPAVISORSECRET=
SERVICE_PASSWORD_VAULTENC=
SERVICE_PASSWORD_LOGFLARE=
SERVICE_PASSWORD_ADMIN=
SERVICE_USER_ADMIN=
SERVICE_USER_MINIO=

# JWT-Tokens (signiert mit SERVICE_PASSWORD_JWT)
SERVICE_SUPABASEANON_KEY=
SERVICE_SUPABASESERVICE_KEY=


############
# Coolify Service-URLs & FQDNs
# Automatisch gesetzt basierend auf der Coolify-Konfiguration.
############

SERVICE_FQDN_SUPABASEKONG=api-xxx.chuchipirat.ch
SERVICE_FQDN_SUPABASEKONG_8000=api-txxx.chuchipirat.ch:8000
SERVICE_URL_SUPABASEKONG=http://api-xxx.chuchipirat.ch
SERVICE_URL_SUPABASEKONG_8000=http://api-txxx.chuchipirat.ch:8000


############
# Database (PostgreSQL)
############

POSTGRES_HOST=
POSTGRES_HOSTNAME=
POSTGRES_PORT=
POSTGRES_DB=postgres
POSTGRES_PASSWORD=${SERVICE_PASSWORD_POSTGRES}
PGPASSWORD=${SERVICE_PASSWORD_POSTGRES}
PG_META_DB_PASSWORD=${SERVICE_PASSWORD_POSTGRES}
DB_PASSWORD=${SERVICE_PASSWORD_POSTGRES}


############
# JWT / Auth Secrets
# Alle referenzieren denselben Wert (SERVICE_PASSWORD_JWT).
############

JWT_SECRET=${SERVICE_PASSWORD_JWT}
JWT_EXPIRY=3600
AUTH_JWT_SECRET=${SERVICE_PASSWORD_JWT}
API_JWT_SECRET=${SERVICE_PASSWORD_JWT}
GOTRUE_JWT_SECRET=${SERVICE_PASSWORD_JWT}
METRICS_JWT_SECRET=${SERVICE_PASSWORD_JWT}
PGRST_JWT_SECRET=${SERVICE_PASSWORD_JWT}
PGRST_APP_SETTINGS_JWT_SECRET=${SERVICE_PASSWORD_JWT}


############
# Supabase Keys & URLs
############

SUPABASE_ANON_KEY=${SERVICE_SUPABASEANON_KEY}
SUPABASE_SERVICE_KEY=${SERVICE_SUPABASESERVICE_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_SUPABASESERVICE_KEY}
SUPABASE_URL=${SERVICE_URL_SUPABASEKONG}
SUPABASE_PUBLIC_URL=${SERVICE_URL_SUPABASEKONG}
SUPABASE_PUBLIC_API=${SERVICE_URL_SUPABASEKONG}
NEXT_PUBLIC_SUPABASE_URL=${SERVICE_URL_SUPABASEKONG}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SERVICE_SUPABASEANON_KEY}


############
# API Proxy (Kong)
############

KONG_STORAGE_CONNECT_TIMEOUT=60
KONG_STORAGE_WRITE_TIMEOUT=3600
KONG_STORAGE_READ_TIMEOUT=3600
KONG_STORAGE_REQUEST_BUFFERING=false
KONG_STORAGE_RESPONSE_BUFFERING=false


############
# API (PostgREST)
############

PGRST_DB_SCHEMAS=public,storage,graphql_public


############
# Auth (GoTrue)
############

## General
API_EXTERNAL_URL=http://api-xxx.chuchipirat.ch
SITE_URL=https://xxx.chuchipirat.ch
GOTRUE_SITE_URL=${SERVICE_URL_SUPABASEKONG}
ADDITIONAL_REDIRECT_URLS=https://xxx.chuchipirat.ch/authservicehandler
DISABLE_SIGNUP=false
ENABLE_ANONYMOUS_USERS=false
GOTRUE_LOG_LEVEL=debug

## Email Auth
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false

## Phone Auth
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

## SMTP
SMTP_ADMIN_EMAIL=noreply@chuchipirat.ch
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=
SMTP_USER=xxx@chuchipirat.ch
SMTP_PASS=
SMTP_SENDER_NAME=chuchipirat

## Mailer URL-Pfade
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

## Mailer Templates (GoTrue lädt diese von der mail-templates Sidecar)
GOTRUE_MAILER_TEMPLATES_CONFIRMATION=http://mail-templates/confirmation.html
GOTRUE_MAILER_TEMPLATES_EMAIL_CHANGE=http://mail-templates/email_change.html
GOTRUE_MAILER_TEMPLATES_RECOVERY=http://mail-templates/recovery.html
MAILER_TEMPLATES_INVITE=
MAILER_TEMPLATES_CONFIRMATION=
MAILER_TEMPLATES_RECOVERY=
MAILER_TEMPLATES_MAGIC_LINK=
MAILER_TEMPLATES_EMAIL_CHANGE=

## Mailer Betreffzeilen
GOTRUE_MAILER_SUBJECTS_CONFIRMATION=chuchipirat: E-Mail-Adresse bestätigen
GOTRUE_MAILER_SUBJECTS_EMAIL_CHANGE=chuchipirat: Neue E-Mail-Adresse bestätigen
GOTRUE_MAILER_SUBJECTS_RECOVERY=chuchipirat: Passwort zurücksetzen
MAILER_SUBJECTS_CONFIRMATION=
MAILER_SUBJECTS_RECOVERY=
MAILER_SUBJECTS_MAGIC_LINK=
MAILER_SUBJECTS_EMAIL_CHANGE=
MAILER_SUBJECTS_INVITE=


############
# Studio (Dashboard)
############

DASHBOARD_USERNAME=${SERVICE_USER_ADMIN}
DASHBOARD_PASSWORD=${SERVICE_PASSWORD_ADMIN}
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
IMGPROXY_ENABLE_WEBP_DETECTION=true
OPENAI_API_KEY=


############
# Supavisor (Connection Pooler)
############

SECRET_KEY_BASE=${SERVICE_PASSWORD_SUPAVISORSECRET}
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100


############
# Vault
############

VAULT_ENC_KEY=${SERVICE_PASSWORD_VAULTENC}


############
# Edge Functions
############

FUNCTIONS_VERIFY_JWT=false
SNIPPETS_MANAGEMENT_FOLDER=/app/snippets
EDGE_FUNCTIONS_MANAGEMENT_FOLDER=/app/edge-functions


############
# Realtime
############

SECRET_PASSWORD_REALTIME=


############
# Storage (MinIO / S3)
############

MINIO_ROOT_USER=${SERVICE_USER_MINIO}
MINIO_ROOT_PASSWORD=${SERVICE_PASSWORD_MINIO}
AWS_ACCESS_KEY_ID=${SERVICE_USER_MINIO}
AWS_SECRET_ACCESS_KEY=${SERVICE_PASSWORD_MINIO}


############
# Logs (Analytics / Logflare)
############

LOGFLARE_API_KEY=${SERVICE_PASSWORD_LOGFLARE}


############
# App-spezifische Variablen (Edge Functions, Cron Jobs)
############

APP_URL=https://xxx.chuchipirat.ch
SENTRY_DSN=
BREVO_API_KEY=
SUPPORT_USER_ID=
PAYREXX_API_SECRET=
VESTABOARD_READ_WRITE_KEY=
