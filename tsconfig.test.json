{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vite/client", "jest", "@testing-library/jest-dom"]
  },
  "include": [
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx",
    "./src/**/__tests__/**/*.ts",
    "./src/**/__tests__/**/*.tsx",
    "./src/**/__mocks__/**/*.ts",
    "./src/**/__test__/**/*.ts"
  ]
}
